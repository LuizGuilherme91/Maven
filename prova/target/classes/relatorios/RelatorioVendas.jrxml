              name="RelatorioVendas" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e6a5dbbe-1234-4567-8901-abcdef123456">
    
    <queryString>
        <![CDATA[SELECT v.id, v.data_venda, v.valor_total, c.nome as cliente_nome FROM venda v INNER JOIN cliente c ON v.cliente_id = c.id]]>
    </queryString>
    
    <field name="id" class="java.lang.Integer"/>
    <field name="data_venda" class="java.sql.Timestamp"/>
    <field name="valor_total" class="java.lang.Double"/>
    <field name="cliente_nome" class="java.lang.String"/>
    
